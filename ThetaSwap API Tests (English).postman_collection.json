    {
      "name": "6. Does not allow token deletion (Security)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Security Check: Resource is protected\", function () {",
              "    // Em APIs de Blockchain, o 404 ou 405 para métodos de escrita (POST/DELETE) ",
              "    // é um comportamento de segurança esperado para evitar manipulação de dados.",
              "    pm.expect(pm.response.code).to.be.oneOf([404, 405]);",
              "});",
              "",
              "// Objective: Security validation to ensure the API is read-only for public consumers.",
              "// QA Note: The 404 response confirms that the server does not expose write endpoints ",
              "// on this resource, preventing unauthorized data modification (Immutability Check)."
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/swap/top-pairs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "swap",
            "top-pairs"
          ]
        },
        "description": "Validates if the API correctly handles a request to a non-existent endpoint."
      },
